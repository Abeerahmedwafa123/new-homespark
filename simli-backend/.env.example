# --- Simli (server-side secrets — NEVER expose to the browser) ---
SIMLI_API_KEY=
SIMLI_FACE_ID=
SIMLI_BASE_URL=https://api.simli.ai
SIMLI_MODEL=fasttalk
SIMLI_MAX_SESSION_LENGTH=3600
SIMLI_MAX_IDLE_TIME=600

# --- CORS: origins allowed to call this API (comma-separated) ---
# Standalone dev = the Vite SPA origin. Add the LMS origin for production.
FRONTEND_ORIGINS=http://localhost:5173
